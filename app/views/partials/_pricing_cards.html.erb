<div class="pricing-table-wrap">
  <table class="pricing-table">
    <thead>
      <tr>
        <th class="pt-feature-col"></th>
        <th>
          <span class="pt-plan-name">Open Source</span>
          <span class="pt-plan-tagline">Public repos &amp; OSS maintainers</span>
          <span class="pt-plan-price">Free</span>
          <span class="pt-plan-unit">forever</span>
          <%= link_to "Get started", "/auth/github?r=sign_up", class: "btn btn-sm btn-outline-secondary", method: :post %>
        </th>
        <th>
          <span class="pt-plan-name">Essentials</span>
          <span class="pt-plan-tagline">Small to mid-size engineering teams</span>
          <span class="pt-plan-price">$69<small>/mo</small></span>
          <span class="pt-plan-unit">per GitHub org</span>
          <% if current_user.nil? %>
            <%= link_to "Start free trial", "/auth/github?r=sign_up", class: "btn btn-sm btn-primary", method: :post %>
          <% else %>
            <%= link_to "Subscribe", settings_path, class: "btn btn-sm btn-primary" %>
          <% end %>
        </th>
        <th class="pt-plan-featured">
          <span class="pt-plan-name">Pro</span>
          <span class="pt-plan-tagline">Large organizations</span>
          <span class="pt-plan-price">$279<small>/mo</small></span>
          <span class="pt-plan-unit">per GitHub org</span>
          <% if current_user.nil? %>
            <%= link_to "Start free trial", "/auth/github?r=sign_up", class: "btn btn-sm btn-primary", method: :post %>
          <% else %>
            <%= link_to "Subscribe", settings_path, class: "btn btn-sm btn-primary" %>
          <% end %>
        </th>
      </tr>
    </thead>
    <tbody>
      <tr class="pt-group"><td colspan="4">Coverage</td></tr>
      <tr>
        <td>GitHub Check annotations</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
      </tr>
      <tr>
        <td>Branch coverage</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
      </tr>
      <tr>
        <td>ERB view coverage <span class="pt-new">new</span></td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
      </tr>
      <tr>
        <td>Coverage dashboards</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
      </tr>

      <tr class="pt-group"><td colspan="4">Scale</td></tr>
      <tr>
        <td>Public repositories</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
      </tr>
      <tr>
        <td>Private repositories</td>
        <td class="pt-none">—</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
      </tr>
      <tr>
        <td>Unlimited team size</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
        <td class="pt-check">✓</td>
      </tr>
      <tr>
        <td>Monthly check builds</td>
        <td class="pt-none">—</td>
        <td>1,000</td>
        <td>Unlimited</td>
      </tr>
      <tr>
        <td>Concurrent builds</td>
        <td class="pt-none">—</td>
        <td>3</td>
        <td>Unlimited</td>
      </tr>

      <tr class="pt-group"><td colspan="4">Support</td></tr>
      <tr>
        <td>API access</td>
        <td class="pt-none">—</td>
        <td class="pt-none">—</td>
        <td class="pt-check">✓</td>
      </tr>
      <tr>
        <td>Email support</td>
        <td class="pt-none">—</td>
        <td class="pt-check">✓</td>
        <td>24h SLA</td>
      </tr>
      <tr>
        <td>Free trial</td>
        <td class="pt-none">—</td>
        <td>14 days</td>
        <td>14 days</td>
      </tr>
    </tbody>
  </table>
  <p class="text-center small mt-3" style="color: var(--muted-text);">
    Pricing is per GitHub organization, not per seat. VAT not included. Yearly discounts available by default.
    <a href="https://grodowski.github.io" target="_blank">Get in touch</a> for custom solutions or self-hosted setups.
  </p>
</div>
