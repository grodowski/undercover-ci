<% content_for(:meta_description) do %>
  Ruby test coverage toolkit ready for the vibe coding era.
<% end %>

<div class="dark-bg hero">
  <div class="container">
    <div class="row align-items-center hero-row">
      <div class="col-lg-6 text-left">
        <h1 class="display-4 header-title">"I've tested all the changes!"<br/><span class="small">Sure you have, Claude.</span></h1>
        <p class="lead my-4">
          We found Claude stops at <strong class="lead-highlight">75% branch coverage</strong> when making changes. Verify your human and AI-written PRs with structure-aware coverage checks, and catch <strong class="lead-highlight">untested changes</strong> before you ship.
        </p>
        <p class="lead hero-bullets">
          🎯 Ship every PR knowing what's tested<br/>
          🛠️ Works with all Ruby testing frameworks<br/>
          🔓 Free forever for open source
        </p>
        <div class="hero-cta">
          <% if current_user.nil? %>
            <%= link_to "Sign Up with GitHub", "/auth/github?r=sign_up", class: "btn btn-lg btn-light font-weight-bold", method: :post %>
            <p class="hero-cta-sub mt-3">
              14-day free trial for private repos. <strong>No seat-based pricing.</strong> Supports Ruby and GitHub.
            </p>
          <% else %>
            <%= link_to "Go to Dashboard", dashboard_path, class: "btn btn-lg btn-light" %>
          <% end %>
        </div>
      </div>
      <div class="col-lg-6 mt-5 mt-lg-0">
        <div class="hero-video">
          <div style="position: relative; padding-bottom: 64.36233611442192%; height: 0;">
            <iframe src="https://www.loom.com/embed/0702e2e7ee4d459c8e1d044396bba906" frameborder="0" webkitallowfullscreen mozallowfullscreen allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;">
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

