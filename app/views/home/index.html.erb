            <p>Shoutout to @mrgrodo's (still underappreciated) work on undercover-ci.com! This little gem helped me keep 99% code coverage in one of my Open Source Ruby gems. Totally recommend it if you care about the quality of your open source work!</p>
          </div>
          <div class="testimonial-author">
            <img src="<%= image_path("avatars/jan-bajena.jpg") %>" alt="Jan Bajena" class="testimonial-avatar">
            <div class="testimonial-info">
              <span class="testimonial-name">Jan Bajena</span>
              <span class="testimonial-title">Senior Software Engineer at Fresha</span>
            </div>
            <a href="https://twitter.com/Bajena/status/1725881690466173076" target="_blank" class="testimonial-link" aria-label="View on X">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <button class="carousel-arrow carousel-arrow--next" aria-label="Next testimonial">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>

  <div class="carousel-dots">
    <button class="carousel-dot" aria-label="Go to testimonial 1"></button>
    <button class="carousel-dot is-active" aria-label="Go to testimonial 2"></button>
    <button class="carousel-dot" aria-label="Go to testimonial 3"></button>
    <button class="carousel-dot" aria-label="Go to testimonial 4"></button>
  </div>
</div>

<script>
(function() {
  let currentIndex = 1;
  let touchStartX = 0;

  function getCards() {
    return Array.from(document.querySelectorAll('.carousel-track .testimonial-card'));
  }

  function updateCarousel(animate = true) {
    const track = document.querySelector('.carousel-track');
    const container = document.querySelector('.carousel-track-container');
    const cards = getCards();
    if (!track || !container || !cards.length) return;

    const cardWidth = cards[0].offsetWidth + 24;
    const offset = (container.offsetWidth / 2) - (cardWidth / 2) - (currentIndex * cardWidth);

    track.style.transition = animate ? 'transform 0.4s ease' : 'none';
    track.style.transform = `translateX(${offset}px)`;

    cards.forEach((card, i) => card.classList.toggle('is-active', i === currentIndex));
    document.querySelectorAll('.carousel-dot').forEach((dot, i) => dot.classList.toggle('is-active', i === currentIndex));
  }

  function goTo(index, animate = true) {
    const numCards = getCards().length;
    if (!numCards) return;
    currentIndex = ((index % numCards) + numCards) % numCards;
    updateCarousel(animate);
  }

  // Event delegation - works with Turbo
  document.addEventListener('click', e => {
    if (e.target.closest('.carousel-arrow--prev')) goTo(currentIndex - 1);
    if (e.target.closest('.carousel-arrow--next')) goTo(currentIndex + 1);

    const dot = e.target.closest('.carousel-dot');
    if (dot) {
      const dots = Array.from(document.querySelectorAll('.carousel-dot'));
      goTo(dots.indexOf(dot));
    }

    const card = e.target.closest('.testimonial-card');
    if (card && !e.target.closest('.testimonial-link')) {
      const cards = getCards();
      const idx = cards.indexOf(card);
      if (idx !== -1 && idx !== currentIndex) goTo(idx);
    }
  });

  document.addEventListener('keydown', e => {
    const carousel = document.querySelector('.testimonials-carousel');
    if (!carousel || !carousel.matches(':hover')) return;
    if (e.key === 'ArrowLeft') goTo(currentIndex - 1);
    if (e.key === 'ArrowRight') goTo(currentIndex + 1);
  });

  document.addEventListener('touchstart', e => {
    if (e.target.closest('.carousel-track')) touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });

  document.addEventListener('touchend', e => {
    if (!e.target.closest('.carousel-track')) return;
    const touchEndX = e.changedTouches[0].screenX;
    if (touchStartX - touchEndX > 50) goTo(currentIndex + 1);
    if (touchEndX - touchStartX > 50) goTo(currentIndex - 1);
  }, { passive: true });

  window.addEventListener('resize', () => updateCarousel(false));

  function init() {
    if (document.querySelector('.testimonials-carousel')) {
      requestAnimationFrame(() => updateCarousel(false));
    }
  }

  document.addEventListener('turbo:load', init);
  document.addEventListener('turbo:render', init);
  document.addEventListener('DOMContentLoaded', init);
  init();
})();
</script>

